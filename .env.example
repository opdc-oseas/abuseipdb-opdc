# Public frontend configuration only.
VITE_OPDC_ENVIRONMENT=production
VITE_OPDC_PROXY_URL=https://opdc-abuseipdb-worker.subscriptions-ec7.workers.dev/

# Sensitive OPDC credentials must stay server-side only.
# Store these in your backend/worker secret manager, never in Vite env files.
OPDC_APP_TOKEN=__STORE_ONLY_IN_SERVER_SECRET_MANAGER__
OPDC_APP_SLUG=__STORE_ONLY_IN_SERVER_SECRET_MANAGER__
